APP_NAME=Hajusrakendus
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Tallinn
APP_URL=http://localhost

APP_LOCALE=et
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=et_EE

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hajusrakendus
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=hajusrakendus_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@hajusrakendus.ee"
MAIL_FROM_NAME="${APP_NAME}"

# Ilmateenuse API
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Kaardi API
RADAR_MAPS_API_KEY=your_radar_maps_api_key_here

# Stripe maksed
STRIPE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

VITE_APP_NAME="${APP_NAME}"
VITE_OPENWEATHER_API_KEY="${OPENWEATHER_API_KEY}"
VITE_RADAR_MAPS_API_KEY="${RADAR_MAPS_API_KEY}"
VITE_STRIPE_KEY="${STRIPE_KEY}"
